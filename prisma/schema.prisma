generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LoadBalanceStrategy {
  ROUND_ROBIN
  RANDOM
}

enum AuthType {
  JWT
  API_KEY
  NONE
}

enum CircuitBreakerStatus {
  CLOSED
  OPEN
  HALF_OPEN
}

model Service {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  baseUrl     String
  healthCheckPath String   @default("/health")
  timeout     Int       @default(5000)
  enabled     Boolean   @default(true)
  loadBalanceStrategy LoadBalanceStrategy @default(ROUND_ROBIN)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  instances   ServiceInstance[]
  routes      Route[]
  circuitBreaker CircuitBreaker?
  
  @@map("services")
}

model ServiceInstance {
  id          String    @id @default(uuid())
  serviceId   String
  url         String
  healthy     Boolean   @default(true)
  lastCheck   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  @@unique([serviceId, url])
  @@map("service_instances")
}

model Route {
  id            String    @id @default(uuid())
  serviceId     String
  path          String
  method        String?   @default("*")
  rewritePath   String?
  authType      AuthType  @default(NONE)
  enabled       Boolean   @default(true)
  extraHeaders  Json?
  rateLimitQps  Int?
  ipRateLimitQps Int?
  tenantId      String?
  grayRules     Json?
  grayUpstream  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  
  @@map("routes")
}

model Tenant {
  id            String    @id @default(uuid())
  name          String    @unique
  rateLimitQps  Int
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  routes        Route[]
  
  @@map("tenants")
}

model RateLimitRule {
  id          String    @id @default(uuid())
  path        String
  method      String?   @default("*")
  dimension   String    // ip, user, path
  limitPerSecond Int?
  limitPerMinute Int?
  limitPerHour Int?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("rate_limit_rules")
}

model ApiKey {
  id          String    @id @default(uuid())
  key         String    @unique
  name        String
  userId      String?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("api_keys")
}

model RequestLog {
  id          String    @id @default(uuid())
  timestamp   DateTime  @default(now())
  path        String
  method      String
  ip          String
  statusCode  Int
  duration    Int
  serviceId   String?
  routeId     String?
  userAgent   String?
  requestBody Json?
  responseBody Json?
  
  @@index([timestamp])
  @@index([path])
  @@index([statusCode])
  @@map("request_logs")
}

model CircuitBreaker {
  id          String    @id @default(uuid())
  serviceId   String    @unique
  status      CircuitBreakerStatus @default(CLOSED)
  failureCount Int     @default(0)
  successCount Int     @default(0)
  lastFailureTime DateTime?
  lastSuccessTime DateTime?
  openUntil   DateTime?
  failureThreshold Int  @default(5)
  timeout     Int       @default(30000)
  halfOpenRequests Int  @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  @@map("circuit_breakers")
}
